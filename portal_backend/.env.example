# .env.example — Copy to .env and fill in your values.
# NEVER commit the real .env file to git.
#
# Dev defaults are shown. Items marked *** CHANGE THIS *** must be updated before production.

# ── Odoo Connection ───────────────────────────────────────────────────────────
# Dev: http://localhost:8069
# Production: https://odoo.yourdomain.com           *** CHANGE THIS ***
ODOO_BASE_URL=http://localhost:8069

# Odoo service account for XML-RPC calls (reads orders, writes deal status).
# Dev: admin / admin (local Odoo only)
# Production: dedicated service user with minimal permissions  *** CHANGE THIS ***
ODOO_API_USER=admin
ODOO_API_PASS=admin

# ── JWT Secret ────────────────────────────────────────────────────────────────
# Must match Odoo's ir.config_parameter key: inbody_portal_api.jwt_secret
# Generate a new secret: python -c "import secrets; print(secrets.token_hex(32))"
#                                                             *** CHANGE THIS ***
JWT_SECRET=inbody-portal-dev-secret-CHANGE-IN-PRODUCTION

# ── Database ──────────────────────────────────────────────────────────────────
# Dev: leave empty — SQLite file (portal_users.db) is auto-created.
# Production: set to Supabase connection string.               *** CHANGE THIS ***
DATABASE_URL=
# DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ── FastAPI Server ────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
# Set to false in production to disable /docs and /redoc.     *** CHANGE THIS ***
DEBUG=true

# ── CORS ──────────────────────────────────────────────────────────────────────
# Production: replace with your actual Vercel domain (JSON array).
# ALLOWED_ORIGINS=["https://your-portal.vercel.app"]          *** CHANGE THIS ***

# ── Odoo DB (AI Engineer feature only — not required for portal) ──────────────
ODOO_DB=inbody_dev
ODOO_DB_USER=odoo_dev
ODOO_DB_PASS=odoo_dev_pass

# ── AI Engineer (optional — remove if not using AI chat features) ─────────────
ANTHROPIC_API_KEY=your-api-key-here
CHROMA_DB_PATH=./chroma_data

# ── Email Alerts (optional — not yet wired up) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
ALERT_FROM_EMAIL=noreply@inbodyindia.com
